{
  "type": "config",
  "id": "conf.system.customimages",
  "title": "Custom Images",
  "queryinfo": {
    "xpath": "//system/customimages",
    "iterable": false
  },
  "properties": {
    "imagefolder": {
      "type": "string",
      "default": "/usr/share/openmediavault/customimages/default/"
    },
    "loginimage": {
      "type": "string",
      "default": "login.jpg"
    },
    "standbyimage": {
      "type": "string",
      "default": "standby.jpg"
    },
    "shutdownimage": {
      "type": "string",
      "default": "shutdown.jpg"
    },
    "lighttheme": {
      "type": "boolean",
      "default": false
    },
    "darktheme": {
      "type": "boolean",
      "default": false
    }
  }
}
