{
  "type": "config",
  "id": "conf.system.customthemes",
  "title": "Custom Themes",
  "queryinfo": {
    "xpath": "//system/customthemes",
    "iterable": false
  },
  "properties": {
    "imagefolder": {
      "type": "string",
      "default": "/usr/share/openmediavault/customthemes/default/"
    },
    "loginimage": {
      "type": "string",
      "default": "login.jpg"
    },
    "standbyimage": {
      "type": "string",
      "default": "standby.jpg"
    },
    "shutdownimage": {
      "type": "string",
      "default": "shutdown.jpg"
    },
    "lighttheme": {
      "type": "boolean",
      "default": false
    },
    "darktheme": {
      "type": "boolean",
      "default": false
    },
    "removecursor": {
      "type": "boolean",
      "default": false
    },
    "customcolor": {
      "type": "boolean",
      "default": false
    },
    "hue": {
      "type": "number",
      "default": 140
    }
  }
}
