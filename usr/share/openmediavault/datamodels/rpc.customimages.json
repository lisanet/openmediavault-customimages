[
  {
    "type": "rpc",
    "id": "rpc.customimages.setsettings",
    "params": {
        "type": "object",
        "properties": {
          "imagefolder": {
            "type": "string",
            "required": true
          },
          "loginimage": {
            "type": "string",
            "pattern": ".*[.](jpg|jpeg)$"
          },
          "standbyimage": {
            "type": "string",
            "pattern": ".*[.](jpg|jpeg)$"
          },
          "shutdownimage": {
            "type": "string",
            "pattern": ".*[.](jpg|jpeg)$"
          }
        }
    }
  }
]
