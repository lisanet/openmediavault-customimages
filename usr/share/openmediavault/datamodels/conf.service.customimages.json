{
  "type": "config",
  "id": "conf.service.customimages",
  "title": "Custom Images",
  "queryinfo": {
    "xpath": "//services/customimages",
    "iterable": false
  },
  "properties": {
    "loginimage": {
      "type": "string",
      "default": "/var/www/openmediavault/assets/images/login.jpg"
    },
    "blendmode": {
      "type": "string",
      "enum": ["normal", "hard-light", "luminosity"],
      "default": "hard-light"
    },
    "standbyimage": {
      "type": "string",
      "default": "/var/www/openmediavault/assets/images/standby.jpg"
    },
    "standbyblendmode": {
      "type": "string",
      "enum": ["normal", "hard-light", "luminosity"],
      "default": "luminosity"
    },
    "shutdownimage": {
      "type": "string",
      "default": "/var/www/openmediavault/assets/images/shutdown.jpg"
    },
    "shutdownblendmode": {
      "type": "string",
      "enum": ["normal", "hard-light", "luminosity"],
      "default": "luminosity"
    }
  }
}
