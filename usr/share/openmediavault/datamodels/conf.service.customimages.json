{
  "type": "config",
  "id": "conf.service.customimages",
  "title": "Custom Images",
  "queryinfo": {
    "xpath": "//services/customimages",
    "iterable": false
  },
  "properties": {
    "loginimage": {
      "type": "string",
      "default": "/usr/share/openmediavault/customimages/default/login.jpg"
    },
    "blendmode": {
      "type": "string",
      "enum": ["normal", "hard-light", "luminosity"],
      "default": "hard-light"
    },
    "standbyimage": {
      "type": "string",
      "default": "/usr/share/openmediavault/customimages/default/standby.jpg"
    },
    "standbyblendmode": {
      "type": "string",
      "enum": ["normal", "hard-light", "luminosity"],
      "default": "luminosity"
    },
    "shutdownimage": {
      "type": "string",
      "default": "/usr/share/openmediavault/customimages/default/shutdown.jpg"
    },
    "shutdownblendmode": {
      "type": "string",
      "enum": ["normal", "hard-light", "luminosity"],
      "default": "luminosity"
    }
  }
}
