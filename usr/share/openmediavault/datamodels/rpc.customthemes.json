[
  {
    "type": "rpc",
    "id": "rpc.customthemes.setsettings",
    "params": {
        "type": "object",
        "properties": {
          "imagefolder": {
            "type": "string",
            "required": true
          },
          "loginimage": {
            "type": "string",
            "pattern": "^$|^.*[.](jpg)$"
          },
          "standbyimage": {
            "type": "string",
            "pattern": "^$|^.*[.](jpg)$"
          },
          "shutdownimage": {
            "type": "string",
            "pattern": "^$|^.*[.](jpg)$"
          },
          "lighttheme": {
            "type": "boolean",
            "required": true
          },
          "darktheme": {
            "type": "boolean",
            "required": true
          },
          "removecursor": {
            "type": "boolean",
            "required": true
          },
          "customcolor": {
            "type": "boolean",
            "required": true
          },
          "hue": {
            "type": "number",
            "minimum": 0,
            "maximum": 360,
            "required": true
          },
          "wallpapers": {
            "type": "boolean",
            "required": true
          }
        }
    }
  }
]
