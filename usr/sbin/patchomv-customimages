#!/bin/bash

change_image()
{
    local type="$1"
    local image=$(echo "$2" | tr -s /)
    [ ! -e "$image" ] && return
    change=$(cmp "$image" "/var/www/openmediavault/assets/images/$type.jpg")
    if [ -n "$change" ]; then
        echo "Set custom $type background"
        sudo cp "$image" "/var/www/openmediavault/assets/images/$type.jpg"
    fi
}

blend_mode()
{
  # blend modes see https://developer.mozilla.org/de/docs/Web/CSS/Reference/Properties/mix-blend-mode
  local type="$1"
  local blendmode="$2"
  local file=$(grep -l "$type.jpg" /var/www/openmediavault/*js)
  if [ -n "$file" ]; then
    grep -q "$type.jpg);object-fit:cover;mix-blend-mode:$blendmode" "$file" && change=no || change=yes
    if [ "$change" = "yes" ]; then
      echo "Set $type background blend mode to $blendmode"
      sudo sed -i -e "s|\($type.jpg);object-fit:cover;mix-blend-mode:\)[^}]*}|\1$blendmode}|" "$file"
    fi
  fi
}

# ---- main ----

if [ -e "/etc/customimages.conf" ]; then
  . /etc/customimages.conf
else
  exit 0
fi

[ -n "$LOGIN_IMAGE" ] && change_image "login" "${IMAGE_FOLDER}/${LOGIN_IMAGE}"
[ -n "$LOGIN_BLENDMODE" ] && blend_mode "login" "$LOGIN_BLENDMODE"
[ -n "$STANDBY_IMAGE" ] && change_image "standby" "${IMAGE_FOLDER}/${STANDBY_IMAGE}"
[ -n "$STANDBY_BLENDMODE" ] && blend_mode "standby" "$STANDBY_BLENDMODE"
[ -n "$SHUTDOWN_IMAGE" ] && change_image "shutdown" "${IMAGE_FOLDER}/${SHUTDOWN_IMAGE}"
[ -n "$SHUTDOWN_BLENDMODE" ] && blend_mode "shutdown" "$SHUTDOWN_BLENDMODE"

exit 0