#!/bin/bash

colors="/var/lib/omv-customthemes/styles-colors.css"
styles_base="/var/lib/omv-customthemes/styles-base.css"
styles_omv="$(find /var/www/openmediavault -type f -name "styles.*.css")"

if cmp -s "$styles_base" "$styles_omv"; then
    echo "Styles-base CSS is up to date"
    exit 0
fi

echo "Updating styles-base CSS"
mkdir -p /var/lib/omv-customthemes
cp "$styles_omv" "$styles_base"

tmp="$(mktemp -t css.XXXXXX)"
# prepare for awk
sed 's|{|{\n|g;s|;|;\n|g;s|}|\n}\n|g;s|}\n\n|}\n|g' "$styles_base" > "$tmp"

# extract only the omv standard color 
awk -v color="#5dacdf" '
function hex2dec(h,    val, i, c) {
    h = tolower(h); val = 0
    for (i = 1; i <= length(h); i++) {
        c = substr(h, i, 1)
        val = val * 16 + (c ~ /[0-9]/ ? c+0 : index("abcdef", c))
    }
    return val
}

BEGIN { block = ""; depth = 0 }

{
    block = block $0 "\n"
    n = split($0, chars, "")
    for (i = 1; i <= n; i++) {
        if (chars[i] == "{") depth++
        if (chars[i] == "}") depth--
    }

    if (depth == 0 && block != "") {
        if (index(block, color) > 0) {
            out = ""
            n = split(block, lines, "\n")
            for (i = 1; i <= n; i++) {
                if (index(lines[i], "{") > 0 || index(lines[i], "}") > 0)
                    out = out lines[i] "\n"
                else if (index(lines[i], color) > 0) {
                    line = lines[i]
                    while (match(line, color "[0-9a-fA-F][0-9a-fA-F]")) {
                        hex = substr(line, RSTART + length(color), 2)
                        alpha = sprintf("%.2f", hex2dec(hex) / 255)
                        repl = "hsl(var(--hue) var(--sat) var(--light) / " alpha ")"
                        sub(color hex, repl, line)
                    }
                    gsub(color, "hsl(var(--hue) var(--sat) var(--light))", line)
                    out = out line "\n"
                }
            }
            print out
        }
        block = ""
    }
}

END {
    print "\n"
}
' "$tmp" | tr -d '\n' > "$colors"

rm -f "$tmp"

