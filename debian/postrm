#!/bin/sh
set -e

. /usr/share/openmediavault/scripts/helper-functions

TARGET="/var/www/openmediavault/assets/images"
PACKAGE="openmediavault-customthemes"

remove_action() {
  dpkg-trigger update-workbench
  rm -f $TARGET/login.jpg
  rm -f $TARGET/standby.jpg
  rm -f $TARGET/shutdown.jpg
  dpkg-divert --package "$PACKAGE" --remove --rename "$TARGET/login.jpg"
  dpkg-divert --package "$PACKAGE" --remove --rename "$TARGET/standby.jpg"
  dpkg-divert --package "$PACKAGE" --remove --rename "$TARGET/shutdown.jpg"
}

case "$1" in
  purge)
    # Activate trigger to rebuild workbench configuration files.
    remove_action
    omv_config_delete "/config/system/customthemes"
    # Remove generated CSS files and directories
    rm -f /var/www/openmediavault/theme.css
    rm -f /var/lib/omv-customthemes/styles-base.css
    rm -f /var/lib/omv-customthemes/styles-colors.css
    rmdir -p /var/lib/omv-customthemes 2>/dev/null || true
    ;;
  remove)
    remove_action
    ;;
  upgrade|failed-upgrade)
    dpkg-trigger update-workbench
    ;;
  abort-upgrade|abort-remove|abort-deconfigure)
    ;;
  *)
    echo "postrm called with unknown argument '$1'" >&2
    exit 1
    ;;

esac

#DEBHELPER#
exit 0
