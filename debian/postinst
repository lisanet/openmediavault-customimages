#!/bin/sh
set -e

. /usr/share/openmediavault/scripts/helper-functions

case "$1" in
  configure)
    # Activate trigger to rebuild workbench configuration files.
    dpkg-trigger update-workbench
    # Initialize and migrate configuration database.
    echo "Updating configuration database ..."
    omv-confdbadm create "conf.service.customimages"
    # Deploy the configuration for autoshutdown services.
    echo "Deploying customimages service configuration"
    #LC_ALL=C.UTF-8 omv-salt deploy run --no-color --quiet customimages
    ;;
  abort-upgrade|abort-remove|abort-deconfigure)
    ;;
  *)
    echo "postinst called with unknown argument '$1'" >&2
    exit 1
    ;;
esac

#DEBHELPER#
exit 0
